// PersonalAssistantForge — Database Schema
// All 14 core entities + cross-cutting tables
// Workers: DO NOT modify existing models. Only ADD fields/models in your domain.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// === CORE ENTITIES ===

model User {
  id             String   @id @default(cuid())
  name           String
  email          String   @unique
  hashedPassword String? // bcrypt hash for credentials auth, null for OAuth-only users
  preferences    Json     @default("{}")
  timezone       String   @default("America/Chicago")
  chronotype     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  entities                   Entity[]
  tasks                      Task[]                       @relation("TaskAssignee")
  actionLogs                 ActionLog[]
  memories                   MemoryEntry[]
  notifications              Notification[]
  attentionBudgets           AttentionBudget[]
  adoptionProgress           AdoptionProgress?
  goalEntries                GoalEntry[]
  vaultEntries               VaultEntry[]
  vaultSecrets               VaultSecret[]
  vaultKeys                  VaultKey[]
  provenanceRecords          ProvenanceRecord[]
  webhookConfigs             WebhookConfig[]
  pluginRecords              PluginRecord[]
  dndConfig                  DNDConfig?
  permissionGrants           PermissionGrant[]
  voiceConsents              VoiceConsent[]
  followUpReminders          FollowUpReminder[]
  cannedResponses            CannedResponse[]
  shadowSessions             ShadowVoiceSession[]
  shadowTrustedDevices       ShadowTrustedDevice[]
  shadowSafetyConfig         ShadowSafetyConfig?
  shadowProactiveConfig      ShadowProactiveConfig?
  shadowChannelEffectiveness ShadowChannelEffectiveness[]
  shadowTriggers             ShadowTrigger[]
  shadowPreferences          ShadowPreference[]
  shadowOutreach             ShadowOutreach[]
  vafIntegrationConfig       VafIntegrationConfig?
}

model Entity {
  id                String   @id @default(cuid())
  userId            String
  name              String
  type              String   @default("Personal")
  complianceProfile String[] @default([])
  brandKit          Json?
  voicePersonaId    String?
  phoneNumbers      String[] @default([])
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user                     User                      @relation(fields: [userId], references: [id])
  contacts                 Contact[]
  tasks                    Task[]
  projects                 Project[]
  events                   CalendarEvent[]
  messages                 Message[]
  documents                Document[]
  knowledgeEntries         KnowledgeEntry[]
  workflows                Workflow[]
  calls                    Call[]
  rules                    Rule[]
  financialRecords         FinancialRecord[]
  decisions                Decision[]
  budgets                  Budget[]
  notifications            Notification[]
  voicePersonas            VoicePersona[]
  runbooks                 Runbook[]
  subscriptions            Subscription[]
  usageRecords             UsageRecord[]
  habitEntries             HabitEntry[]
  healthMetrics            HealthMetric[]
  legalHolds               LegalHold[]
  retentionPolicies        RetentionPolicy[]
  shadowVoiceSessions      ShadowVoiceSession[]
  shadowEntityProfile      ShadowEntityProfile?
  shadowRetentionConfig    ShadowRetentionConfig?
  voiceforgeCallPlaybooks  VoiceforgeCallPlaybook[]
  voiceforgeConsentConfigs VoiceforgeConsentConfig[]

  @@index([userId])
}

model Contact {
  id                String    @id @default(cuid())
  entityId          String
  name              String
  email             String?
  phone             String?
  channels          Json      @default("[]")
  relationshipScore Int       @default(50)
  lastTouch         DateTime?
  commitments       Json      @default("[]")
  preferences       Json      @default("{}")
  tags              String[]  @default([])
  deletedAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  entity         Entity                 @relation(fields: [entityId], references: [id])
  messages       Message[]              @relation("ContactMessages")
  calls          Call[]
  callPreference ContactCallPreference?

  @@index([entityId])
  @@index([email])
  @@index([deletedAt])
}

model Task {
  id           String    @id @default(cuid())
  title        String
  description  String?
  entityId     String
  projectId    String?
  priority     String    @default("P1")
  status       String    @default("TODO")
  dueDate      DateTime?
  dependencies String[]  @default([])
  assigneeId   String?
  createdFrom  Json?
  tags         String[]  @default([])
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  entity   Entity   @relation(fields: [entityId], references: [id])
  project  Project? @relation(fields: [projectId], references: [id])
  assignee User?    @relation("TaskAssignee", fields: [assigneeId], references: [id])

  @@index([entityId])
  @@index([projectId])
  @@index([status])
  @@index([priority])
  @@index([title])
  @@index([deletedAt])
}

model Project {
  id          String   @id @default(cuid())
  name        String
  entityId    String
  description String?
  milestones  Json     @default("[]")
  status      String   @default("TODO")
  health      String   @default("GREEN")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  entity Entity @relation(fields: [entityId], references: [id])
  tasks  Task[]

  @@index([entityId])
}

model CalendarEvent {
  id             String   @id @default(cuid())
  title          String
  entityId       String
  participantIds String[] @default([])
  startTime      DateTime
  endTime        DateTime
  bufferBefore   Int?
  bufferAfter    Int?
  prepPacket     Json?
  meetingNotes   String?
  recurrence     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  entity Entity @relation(fields: [entityId], references: [id])

  @@index([entityId])
  @@index([startTime])
}

model Message {
  id          String    @id @default(cuid())
  channel     String
  senderId    String
  recipientId String
  entityId    String
  threadId    String?
  subject     String?
  body        String
  triageScore Int       @default(5)
  intent      String?
  sensitivity String    @default("INTERNAL")
  draftStatus String?
  read        Boolean   @default(false)
  starred     Boolean   @default(false)
  attachments Json      @default("[]")
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  entity  Entity   @relation(fields: [entityId], references: [id])
  contact Contact? @relation("ContactMessages", fields: [senderId], references: [id])

  @@index([entityId])
  @@index([threadId])
  @@index([triageScore])
  @@index([subject])
  @@index([body])
  @@index([deletedAt])
}

model Document {
  id         String    @id @default(cuid())
  title      String
  entityId   String
  type       String
  version    Int       @default(1)
  templateId String?
  citations  Json      @default("[]")
  content    String?
  status     String    @default("DRAFT")
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  entity Entity @relation(fields: [entityId], references: [id])

  @@index([entityId])
  @@index([type])
  @@index([title])
  @@index([deletedAt])
}

model KnowledgeEntry {
  id             String   @id @default(cuid())
  content        String
  tags           String[] @default([])
  entityId       String
  source         String
  linkedEntities String[] @default([])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  entity Entity @relation(fields: [entityId], references: [id])

  @@index([entityId])
  @@index([content])
}

model Workflow {
  id          String    @id @default(cuid())
  name        String
  entityId    String
  triggers    Json      @default("[]")
  steps       Json      @default("[]")
  status      String    @default("DRAFT")
  lastRun     DateTime?
  successRate Float     @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  entity Entity @relation(fields: [entityId], references: [id])

  @@index([entityId])
  @@index([status])
}

model Call {
  id           String   @id @default(cuid())
  entityId     String
  contactId    String?
  direction    String
  personaId    String?
  scriptId     String?
  outcome      String?
  transcript   String?
  recordingUrl String?
  sentiment    Float?
  duration     Int?
  actionItems  Json     @default("[]")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  entity  Entity   @relation(fields: [entityId], references: [id])
  contact Contact? @relation(fields: [contactId], references: [id])

  @@index([entityId])
  @@index([contactId])
}

model Rule {
  id         String   @id @default(cuid())
  name       String
  scope      String   @default("GLOBAL")
  entityId   String?
  condition  Json
  action     Json
  precedence Int      @default(0)
  createdBy  String   @default("HUMAN")
  version    Int      @default(1)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  entity Entity? @relation(fields: [entityId], references: [id])

  @@index([scope])
  @@index([isActive])
}

model ActionLog {
  id           String   @id @default(cuid())
  actor        String
  actorId      String?
  actionType   String
  target       String
  reason       String
  blastRadius  String   @default("LOW")
  reversible   Boolean  @default(true)
  rollbackPath String?
  status       String   @default("PENDING")
  cost         Float?
  timestamp    DateTime @default(now())

  user User? @relation(fields: [actorId], references: [id])

  @@index([actor])
  @@index([actionType])
  @@index([timestamp])
}

model FinancialRecord {
  id          String    @id @default(cuid())
  entityId    String
  type        String
  amount      Float
  currency    String    @default("USD")
  status      String    @default("PENDING")
  dueDate     DateTime?
  category    String
  vendor      String?
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  entity Entity @relation(fields: [entityId], references: [id])

  @@index([entityId])
  @@index([type])
  @@index([status])
}

model ConsentReceipt {
  id           String   @id @default(cuid())
  actionId     String
  description  String
  reason       String
  impacted     String[] @default([])
  reversible   Boolean  @default(true)
  rollbackLink String?
  confidence   Float    @default(0.5)
  timestamp    DateTime @default(now())

  @@index([actionId])
}

model MemoryEntry {
  id           String   @id @default(cuid())
  userId       String
  type         String
  content      String
  context      String
  strength     Float    @default(1.0)
  lastAccessed DateTime @default(now())
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([type])
}

// === PHASE 2 MODELS ===

model Decision {
  id           String    @id @default(cuid())
  entityId     String
  entity       Entity    @relation(fields: [entityId], references: [id], onDelete: Cascade)
  title        String
  type         String // e.g., "strategic", "operational", "financial", "hiring", "product"
  status       String    @default("open") // "open", "in_review", "decided", "deferred", "cancelled"
  options      Json // Array of option objects: [{ id, label, description, pros, cons, score }]
  matrix       Json? // Decision matrix: { criteria: [...], weights: [...], scores: {...} }
  outcome      String? // Selected option or final decision text
  rationale    String? // Why this decision was made
  deadline     DateTime?
  decidedAt    DateTime?
  decidedBy    String?
  stakeholders Json? // Array of { userId, role, vote }
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([entityId])
  @@index([status])
  @@index([deadline])
}

model Budget {
  id        String    @id @default(cuid())
  entityId  String
  entity    Entity    @relation(fields: [entityId], references: [id], onDelete: Cascade)
  name      String
  amount    Float // total budget amount in cents
  spent     Float     @default(0) // amount spent so far
  period    String // "monthly", "quarterly", "yearly", "project"
  category  String // e.g., "marketing", "engineering", "operations", "travel"
  startDate DateTime?
  endDate   DateTime?
  alerts    Json? // Array of { threshold: number, type: "percentage"|"absolute", notified: boolean }
  notes     String?
  status    String    @default("active") // "active", "paused", "exhausted", "closed"
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([entityId])
  @@index([category])
  @@index([status])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  entityId  String?
  entity    Entity?   @relation(fields: [entityId], references: [id], onDelete: SetNull)
  type      String // "task_due", "message_received", "workflow_completed", "alert", "payment", "system"
  title     String
  body      String
  read      Boolean   @default(false)
  readAt    DateTime?
  actionUrl String? // URL to navigate to when notification is clicked
  metadata  Json? // Additional context data
  priority  String    @default("normal") // "low", "normal", "high", "urgent"
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([entityId])
  @@index([read])
  @@index([createdAt])
}

model VoicePersona {
  id          String   @id @default(cuid())
  entityId    String
  entity      Entity   @relation(fields: [entityId], references: [id], onDelete: Cascade)
  name        String // Display name (e.g., "Professional", "Casual", "Executive")
  voiceId     String // External TTS voice ID (e.g., ElevenLabs voice ID)
  provider    String   @default("elevenlabs") // "elevenlabs", "azure", "google", "amazon"
  settings    Json // { speed, pitch, stability, similarity, style, speakerBoost }
  description String? // When to use this persona
  isDefault   Boolean  @default(false)
  sampleUrl   String? // URL to a sample audio clip
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([entityId, name])
  @@index([entityId])
}

model Runbook {
  id          String    @id @default(cuid())
  entityId    String
  entity      Entity    @relation(fields: [entityId], references: [id], onDelete: Cascade)
  name        String
  description String?
  steps       Json // Array of { id, order, action, params, onSuccess, onFailure, timeout }
  variables   Json? // Array of { name, type, defaultValue, required, description }
  category    String // "incident", "onboarding", "deployment", "maintenance", "compliance"
  trigger     String? // "manual", "scheduled", "event", "condition"
  schedule    String? // Cron expression if trigger is "scheduled"
  isActive    Boolean   @default(true)
  lastRunAt   DateTime?
  runCount    Int       @default(0)
  version     Int       @default(1)
  createdBy   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([entityId])
  @@index([category])
  @@index([isActive])
}

// === PHASE 3 MODELS ===

model Subscription {
  id                   String   @id @default(cuid())
  entityId             String
  entity               Entity   @relation(fields: [entityId], references: [id], onDelete: Cascade)
  planId               String // "free", "starter", "professional", "enterprise"
  status               String   @default("active") // "active", "past_due", "canceled", "trialing"
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  stripeCustomerId     String?
  stripeSubscriptionId String?
  cancelAtPeriodEnd    Boolean  @default(false)
  metadata             Json?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([entityId])
  @@index([status])
  @@index([stripeCustomerId])
}

model UsageRecord {
  id           String   @id @default(cuid())
  entityId     String
  entity       Entity   @relation(fields: [entityId], references: [id], onDelete: Cascade)
  model        String // AI model used (e.g., "claude-sonnet-4-5-20250929")
  inputTokens  Int
  outputTokens Int
  cost         Float // cost in USD
  module       String // which module made the call (e.g., "inbox", "calendar")
  userId       String?
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([entityId])
  @@index([module])
  @@index([createdAt])
}

model HabitEntry {
  id              String   @id @default(cuid())
  entityId        String
  entity          Entity   @relation(fields: [entityId], references: [id], onDelete: Cascade)
  name            String
  description     String?
  frequency       String // "daily", "weekly", "weekdays", "custom"
  targetPerPeriod Int      @default(1)
  streak          Int      @default(0)
  longestStreak   Int      @default(0)
  completedDates  Json     @default("[]") // Array of ISO date strings
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([entityId])
  @@index([isActive])
}

model HealthMetric {
  id         String   @id @default(cuid())
  entityId   String
  entity     Entity   @relation(fields: [entityId], references: [id], onDelete: Cascade)
  type       String // "sleep", "stress", "energy", "heart_rate", "steps", "weight"
  value      Float
  unit       String // "hours", "score", "bpm", "steps", "kg"
  source     String   @default("manual") // "manual", "apple_health", "fitbit", "oura", "whoop", "garmin"
  metadata   Json? // Additional data (e.g., sleep stages, stress factors)
  recordedAt DateTime
  createdAt  DateTime @default(now())

  @@index([entityId])
  @@index([type])
  @@index([recordedAt])
}

// === PERSISTENCE MIGRATION MODELS ===

model AttentionBudget {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  entityId        String?
  date            DateTime @default(now())
  totalMinutes    Int      @default(10)
  consumedMinutes Int      @default(0)
  resetAt         DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
}

model AdoptionProgress {
  id             String    @id @default(cuid())
  userId         String    @unique
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  phase          String    @default("Inbox Mastery")
  completedSteps Json      @default("[]")
  ahaMoments     Json      @default("[]")
  data           Json      @default("{}")
  startedAt      DateTime  @default(now())
  completedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([phase])
}

model GoalEntry {
  id                String    @id @default(cuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  entityId          String?
  title             String
  description       String?
  framework         String    @default("CUSTOM")
  targetValue       Float
  currentValue      Float     @default(0)
  unit              String
  milestones        Json      @default("[]")
  startDate         DateTime
  endDate           DateTime
  status            String    @default("ON_TRACK")
  autoProgress      Boolean   @default(false)
  linkedTaskIds     Json      @default("[]")
  linkedWorkflowIds Json      @default("[]")
  deadline          DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([entityId])
  @@index([status])
}

// === PERSISTENCE EXPANSION MODELS ===

model VaultEntry {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label         String
  encryptedData String
  iv            String
  tag           String
  algorithm     String   @default("aes-256-gcm")
  keyVersion    Int      @default(1)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, label])
  @@index([userId])
}

model VaultSecret {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  encryptedValue String
  iv             String
  tag            String
  version        Int      @default(1)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([userId, name])
}

model VaultKey {
  id                   String    @id @default(cuid())
  userId               String
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  keyId                String    @unique
  encryptedKeyMaterial String
  algorithm            String
  status               String    @default("ACTIVE")
  createdAt            DateTime  @default(now())
  rotatedAt            DateTime?

  @@index([userId])
}

model ProvenanceRecord {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  entityId       String?
  targetType     String?
  targetId       String?
  inputHash      String
  outputHash     String
  modelId        String
  promptTemplate String?
  metadata       Json?
  timestamp      DateTime @default(now())

  @@index([userId])
  @@index([outputHash])
  @@index([entityId])
  @@index([targetType, targetId])
}

model WebhookConfig {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  url       String
  events    Json
  secret    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  webhookEvents WebhookEvent[]

  @@index([userId])
}

model WebhookEvent {
  id              String        @id @default(cuid())
  webhookConfigId String
  webhookConfig   WebhookConfig @relation(fields: [webhookConfigId], references: [id], onDelete: Cascade)
  event           String
  payload         Json
  status          String        @default("PENDING")
  response        Json?
  attempts        Int           @default(0)
  lastAttemptAt   DateTime?
  createdAt       DateTime      @default(now())

  @@index([webhookConfigId])
  @@index([status])
}

model PluginRecord {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  version     String
  author      String?
  description String?
  permissions Json
  status      String   @default("ACTIVE")
  config      Json?
  installedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  pluginReviews PluginReview[]

  @@unique([userId, name])
}

model PluginReview {
  id             String       @id @default(cuid())
  pluginRecordId String
  pluginRecord   PluginRecord @relation(fields: [pluginRecordId], references: [id], onDelete: Cascade)
  reviewerId     String
  status         String       @default("PENDING")
  findings       Json
  riskScore      Float?
  reviewedAt     DateTime?
  revokedAt      DateTime?
  affectedUsers  Int          @default(0)
  createdAt      DateTime     @default(now())

  @@index([pluginRecordId])
}

model DNDConfig {
  id                     String   @id @default(cuid())
  userId                 String   @unique
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  isActive               Boolean  @default(false)
  mode                   String   @default("MANUAL")
  startTime              String?
  endTime                String?
  vipBreakthroughEnabled Boolean  @default(false)
  vipContactIds          Json     @default("[]")
  calendarIntegration    Boolean  @default(false)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model PermissionGrant {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  resource  String
  actions   Json
  grantedBy String?
  grantedAt DateTime  @default(now())
  expiresAt DateTime?
  revoked   Boolean   @default(false)

  @@unique([userId, resource])
  @@index([userId])
}

model VoiceConsent {
  id               String    @id @default(cuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  voiceCloneId     String
  consentGiven     Boolean   @default(true)
  consentTimestamp DateTime  @default(now())
  revokedAt        DateTime?

  @@unique([userId, voiceCloneId])
}

// === INBOX & COMPLIANCE PERSISTENCE MODELS ===

model FollowUpReminder {
  id          String    @id @default(cuid())
  userId      String
  messageId   String?
  description String
  dueDate     DateTime
  priority    String    @default("NORMAL")
  completed   Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([dueDate])
}

model CannedResponse {
  id        String   @id @default(cuid())
  userId    String
  title     String
  content   String
  tags      String[] @default([])
  shortcut  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, title])
  @@index([userId])
}

model LegalHold {
  id         String    @id @default(cuid())
  entityId   String
  reason     String
  scope      Json
  status     String    @default("ACTIVE")
  createdBy  String
  releasedBy String?
  createdAt  DateTime  @default(now())
  releasedAt DateTime?
  updatedAt  DateTime  @updatedAt

  entity Entity @relation(fields: [entityId], references: [id])

  @@index([entityId])
  @@index([status])
}

model RetentionPolicy {
  id               String    @id @default(cuid())
  entityId         String
  dataType         String
  action           String    @default("ARCHIVE")
  retentionDays    Int
  schedule         String    @default("DAILY")
  isActive         Boolean   @default(true)
  lastExecutedAt   DateTime?
  executionHistory Json      @default("[]")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  entity Entity @relation(fields: [entityId], references: [id])

  @@unique([entityId, dataType])
  @@index([entityId])
}

// === SHADOW VOICE AGENT MODELS ===

model ShadowVoiceSession {
  id                   String    @id @default(cuid())
  userId               String
  status               String    @default("active")
  currentChannel       String
  channelHistory       Json      @default("[]")
  activeEntityId       String?
  currentPage          String?
  currentWorkflowId    String?
  currentWorkflowStep  Int?
  recordingUrls        Json      @default("[]")
  fullTranscript       String?
  aiSummary            String?
  approvals            Json      @default("[]")
  startedAt            DateTime  @default(now())
  lastActivityAt       DateTime  @default(now())
  endedAt              DateTime?
  totalDurationSeconds Int       @default(0)
  messageCount         Int       @default(0)

  user            User                   @relation(fields: [userId], references: [id])
  entity          Entity?                @relation(fields: [activeEntityId], references: [id])
  messages        ShadowMessage[]
  outcome         ShadowSessionOutcome?
  consentReceipts ShadowConsentReceipt[]
  authEvents      ShadowAuthEvent[]

  @@index([userId])
  @@index([status])
  @@index([activeEntityId])
}

model ShadowMessage {
  id           String   @id @default(cuid())
  sessionId    String
  role         String
  content      String
  contentType  String   @default("TEXT")
  intent       String?
  toolsUsed    Json     @default("[]")
  actionsTaken Json     @default("[]")
  audioUrl     String?
  channel      String
  confidence   Float?
  latencyMs    Int?
  telemetry    Json?
  // VAF integration fields (additive, all nullable)
  sttProvider  String?  @map("stt_provider") @db.VarChar(20)
  ttsProvider  String?  @map("tts_provider") @db.VarChar(20)
  audioQuality Json?    @map("audio_quality")
  sentiment    Json?
  createdAt    DateTime @default(now())

  session ShadowVoiceSession @relation(fields: [sessionId], references: [id])

  @@index([sessionId])
  @@index([createdAt])
}

model ShadowConsentReceipt {
  id                   String    @id @default(cuid())
  sessionId            String?
  messageId            String?
  actionType           String
  actionDescription    String
  triggerSource        String
  triggerReferenceType String?
  triggerReferenceId   String?
  reasoning            String?
  sourcesCited         Json      @default("[]")
  confirmationLevel    String
  confirmationMethod   String?
  blastRadius          String
  affectedCount        Int       @default(0)
  financialImpact      Float     @default(0)
  reversible           Boolean   @default(false)
  rollbackPath         String?
  aiCost               Float     @default(0)
  telephonyCost        Float     @default(0)
  entityId             String?
  executedAt           DateTime  @default(now())
  rolledBackAt         DateTime?
  rolledBackBy         String?

  session ShadowVoiceSession? @relation(fields: [sessionId], references: [id])

  @@index([sessionId])
  @@index([actionType])
  @@index([entityId])
  @@index([executedAt])
}

model ShadowSessionOutcome {
  id                   String   @id @default(cuid())
  sessionId            String   @unique
  decisionsMade        Json     @default("[]")
  commitments          Json     @default("[]")
  deadlinesSet         Json     @default("[]")
  followUps            Json     @default("[]")
  recordsCreated       Json     @default("[]")
  recordsUpdated       Json     @default("[]")
  recordsLinked        Json     @default("[]")
  extractionConfidence Float?
  userVerified         Boolean  @default(false)
  createdAt            DateTime @default(now())

  session ShadowVoiceSession @relation(fields: [sessionId], references: [id])
}

model ShadowTrustedDevice {
  id                String    @id @default(cuid())
  userId            String
  deviceType        String
  deviceFingerprint String?
  phoneNumber       String?
  name              String
  verifiedAt        DateTime  @default(now())
  lastUsedAt        DateTime?
  isActive          Boolean   @default(true)

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([phoneNumber])
}

model ShadowAuthEvent {
  id              String   @id @default(cuid())
  sessionId       String?
  method          String
  result          String
  riskLevel       String?
  actionAttempted String?
  createdAt       DateTime @default(now())

  session ShadowVoiceSession? @relation(fields: [sessionId], references: [id])

  @@index([sessionId])
}

model ShadowSafetyConfig {
