# PersonalAssistantForge — Environment Variables
# Copy to .env.local and fill in real values

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/paf_dev

# Auth
NEXTAUTH_SECRET=YOUR_NEXTAUTH_SECRET_HERE
NEXTAUTH_URL=http://localhost:3000

# AI / LLM
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY_HERE
OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE

# Voice / Telephony
TWILIO_ACCOUNT_SID=YOUR_TWILIO_SID_HERE
TWILIO_AUTH_TOKEN=YOUR_TWILIO_TOKEN_HERE
TWILIO_PHONE_NUMBER=YOUR_TWILIO_NUMBER_HERE

# TTS / STT
DEEPGRAM_API_KEY=YOUR_DEEPGRAM_KEY_HERE
ELEVENLABS_API_KEY=YOUR_ELEVENLABS_KEY_HERE

# Integrations
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET_HERE
PLAID_CLIENT_ID=YOUR_PLAID_CLIENT_ID_HERE
PLAID_SECRET=YOUR_PLAID_SECRET_HERE

# Redis / Queue
REDIS_URL=redis://localhost:6379

# Storage (S3)
S3_BUCKET=YOUR_S3_BUCKET_HERE
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Monitoring
SENTRY_DSN=YOUR_SENTRY_DSN_HERE

# Email
EMAIL_FROM=noreply@example.com
SENDGRID_API_KEY=SG.your-key-here

# Security / Encryption
VAULT_MASTER_KEY=your-32-byte-hex-key
CLAMAV_HOST=

# CORS
ALLOWED_ORIGIN=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Payments
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Health / Wearable Integrations
APPLE_HEALTH_API_KEY=
FITBIT_CLIENT_ID=
FITBIT_CLIENT_SECRET=
GARMIN_API_KEY=
GARMIN_API_SECRET=
OURA_API_KEY=
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=

# Document Processing
GOOGLE_VISION_API_KEY=

# Voice Wake Word
PICOVOICE_ACCESS_KEY=
